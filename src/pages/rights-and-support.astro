---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Rights and support | Disabled agricultural workers";
const description =
  "Explore the rights themes, barriers, and support issues affecting disabled agricultural workers and their families in agricultural settings.";
---

<BaseLayout
  title={title}
  description={description}
  path="/rights-and-support"
  breadcrumbs={[{ label: "Rights & Support" }]}
>
  <section class="content-grid">
    <article class="page-panel">
      <p class="eyebrow">Rights and support</p>
      <h1>Key issues affecting disabled agricultural workers and families</h1>
      <p class="lead">
        IAAWD&apos;s published materials emphasise legal and property-rights advocacy,
        family welfare, and public education around disability in agricultural
        settings.
      </p>
      <p>
        The site does not claim to solve every problem directly. It does, however,
        point visitors to the core themes that matter: equal treatment, access to
        information, family impact, and the need for visible advocacy where disability
        and rural legal issues overlap.
      </p>
    </article>

    <aside class="notice-card">
      <h2>Main themes on this site</h2>
      <ul class="bullet-list">
        <li>Disability and unequal treatment in agricultural contexts.</li>
        <li>Legal and property-rights questions affecting family welfare.</li>
        <li>Need for public education and policy attention.</li>
        <li>Need for accessible routes to contact, governance, and documents.</li>
      </ul>
    </aside>
  </section>

  <section class="cards-grid">
    <article class="grid-card">
      <h2>Advocacy</h2>
      <p>
        The governing document refers to advocacy for equitable legal and property
        rights in agricultural settings and to legislative change where stronger
        protection is needed.
      </p>
    </article>

    <article class="grid-card">
      <h2>Family impact</h2>
      <p>
        IAAWD&apos;s scope includes family members, recognising that disability and rural
        legal disputes often affect wider household welfare and security.
      </p>
    </article>

    <article class="grid-card">
      <h2>Public education</h2>
      <p>
        The organisation&apos;s materials aim to make difficult issues easier for the
        public, policymakers, and supporters to understand.
      </p>
    </article>
  </section>

  <section class="panel-grid">
    <article class="page-panel">
      <h2>Where to go next</h2>
      <ul class="bullet-list">
        <li>Open the resources page for the governing document and related links.</li>
        <li>Review governance for trustee-led structure and document access.</li>
        <li>Use the contact page for direct communication.</li>
      </ul>
    </article>

    <article class="cta-panel">
      <h2>Related pages</h2>
      <p class="mini-links">
        <a href="/resources">Resources</a>
        <a href="/governance">Governance</a>
        <a href="/contact">Contact</a>
      </p>
    </article>
  </section>
</BaseLayout>
