---
import BaseLayout from "../layouts/BaseLayout.astro";
import { FAQ_ITEMS } from "../data/siteContent.js";

const title = "IAAWD FAQ | Disabled agricultural workers information";
const description =
  "Find answers about IAAWD, who it serves, governance, contact details, and where to find public documents and support information.";

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: FAQ_ITEMS.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer,
      },
    })),
  },
];
---

<BaseLayout
  title={title}
  description={description}
  path="/faq"
  breadcrumbs={[{ label: "FAQ" }]}
  schemas={schemas}
>
  <section class="page-panel shell">
    <p class="eyebrow">Frequently asked questions</p>
    <h1>Answers about IAAWD, governance, and contact routes</h1>
    <p class="lead">
      This page gives a direct introduction to IAAWD for visitors who want quick,
      source-grounded answers before reading the full mission, governance, or
      resource pages.
    </p>
  </section>

  <section class="faq-list shell">
    {
      FAQ_ITEMS.map((item) => (
        <article class="faq-item">
          <h2>{item.question}</h2>
          <p>{item.answer}</p>
          <p><a href={item.href}>{item.linkLabel}</a></p>
        </article>
      ))
    }
  </section>
</BaseLayout>
