---
import { NAV_LINKS, SITE } from "../config/site.js";

const { currentPath = "/" } = Astro.props;
---

<header class="site-header">
  <div class="shell header-shell">
    <a class="brand" href="/">
      <img
        src={SITE.logoPath}
        alt="International Association for Agricultural Workers with Disabilities logo"
        width="64"
        height="64"
      />
      <span>
        <strong>{SITE.shortName}</strong>
        <small>{SITE.name}</small>
      </span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav-list">
        {
          NAV_LINKS.map((link) => {
            const isActive = currentPath === link.href;
            return (
              <li>
                <a href={link.href} aria-current={isActive ? "page" : undefined}>
                  {link.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>
